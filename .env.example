# Application
# Role decides whether this process runs the HTTP API or the background worker.
APP_ROLE=api
NODE_ENV=development
PORT=3000
# Lowest structured-log level emitted: error < warn < log < debug < verbose.
LOG_LEVEL=log

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=webhook
POSTGRES_PASSWORD=webhook
POSTGRES_DB=webhook_ingestion
# Connection pool ceiling. Keep >= RABBITMQ_PREFETCH: each in-flight message
# holds one connection for its transaction, plus one for the health ping.
POSTGRES_POOL_SIZE=10

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# Overrides the host/port/user/password composition above when set.
RABBITMQ_URL=
PUBLISH_CONFIRM_TIMEOUT_MS=5000
# Unacked messages a worker channel takes at once (its processing concurrency).
RABBITMQ_PREFETCH=10

# Ingestion
# Anti-replay tolerance: reject a delivery whose signed timestamp is off by more.
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
# Caps the request body the HMAC runs over, so it never hashes an unbounded payload.
WEBHOOK_BODY_LIMIT=100kb
# Per-IP request ceiling on the ingestion endpoint, counted before the HMAC
# check so a flood cannot burn CPU on signatures. In-memory, per process.
# Raise RATE_LIMIT_MAX (e.g. 10000) when running the latency smoke test.
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=600

# Processing
# Total attempts before a transient failure is sent to the DLQ.
# 4 = first pass + one retry per backoff tier (5s, 30s, 2m).
MAX_PROCESSING_ATTEMPTS=4

# Observability
# The api serves GET /metrics on its own port; the worker has no HTTP role,
# so it exposes the same Prometheus format on this dedicated port instead.
WORKER_METRICS_PORT=9091

# Demo
# Enables the live demo surface: worker telemetry, WebSocket feed, scripted failures, CORS.
# Read with a strict string comparison: only the exact value "true" turns it on.
# Refused at boot when NODE_ENV=production, because it swaps in public credentials.
DEMO_MODE=false
# Public-by-design credentials used only when DEMO_MODE is on. The demo compose override
# maps them onto WEBHOOK_HMAC_SECRET and ADMIN_API_KEY; the guards never read these names.
DEMO_WEBHOOK_HMAC_SECRET=demo-hmac-secret-public
DEMO_ADMIN_API_KEY=demo-admin-key-public
# Origin allowed by the demo CORS policy and by the WebSocket gateway handshake.
WEB_ORIGIN=http://localhost:5173

# Secrets (set real values in .env; never commit them)
# Shared secret used to verify inbound HMAC-SHA256 signatures at the boundary.
WEBHOOK_HMAC_SECRET=change-me
# Key required to reach the DLQ inspection endpoints.
ADMIN_API_KEY=change-me
