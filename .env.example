# Application
# Role decides whether this process runs the HTTP API or the background worker (D-008).
APP_ROLE=api
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=webhook
POSTGRES_PASSWORD=webhook
POSTGRES_DB=webhook_ingestion

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# Overrides the host/port/user/password composition above when set.
RABBITMQ_URL=
PUBLISH_CONFIRM_TIMEOUT_MS=5000

# Ingestion
# Anti-replay tolerance: reject a delivery whose signed timestamp is off by more.
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
# Caps the request body the HMAC runs over, so it never hashes an unbounded payload.
WEBHOOK_BODY_LIMIT=100kb

# Processing
# Total attempts before a transient failure is sent to the DLQ (RF-07).
MAX_PROCESSING_ATTEMPTS=3

# Secrets (set real values in .env; never commit them)
# Shared secret used to verify inbound HMAC-SHA256 signatures at the boundary.
WEBHOOK_HMAC_SECRET=change-me
# Key required to reach the DLQ inspection endpoints.
ADMIN_API_KEY=change-me
